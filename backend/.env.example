# ── 必填 ──────────────────────────────────────────────────────────────────────

# JWT（與 LocalAuth 共用，用於驗證 access_token）
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-jwt-secret-here

# NeuroSme2.0 專用 PostgreSQL
# port 5434 避免與 LocalAuth 的 PostgreSQL（5433）衝突
DATABASE_URL=postgresql://neurosme:neurosme_secret@localhost:5434/neurosme2

# LLM API Key 加密用對稱金鑰（Fernet，32-byte URL-safe base64）
# 產生方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
LLM_ENCRYPTION_KEY=your-fernet-key-here

# Activation Code 簽名用 secret（HMAC-SHA256）
# 產生方式：python -c "import secrets; print(secrets.token_hex(32))"
ACTIVATION_SECRET=your-activation-secret-here

# ── LocalAuth Admin API ───────────────────────────────────────────────────────
# 後端代理用，勿暴露給前端
# 僅 on-prem / REGISTRATION_DISABLED=true 場景需設定；SaaS 自助註冊時留空即可
LOCALAUTH_ADMIN_URL=http://localhost:4000
LOCALAUTH_ADMIN_API_KEY=your-localauth-admin-api-key-here

# ── 資料目錄 ──────────────────────────────────────────────────────────────────

# Chat 附加檔（stored_files）實體 blob 根目錄
# - 相對路徑：相對於 backend/（實際為 backend/data/stored_files/{tenant_id}/{file_id}/blob）
# - 可改為絕對路徑，例如 /var/lib/neurosme/stored_files
# - 未設定或留空時，預設為 data/stored_files
STORED_FILES_DIR=data/stored_files

# DuckDB 長存目錄（BI 計算資料的 .duckdb 檔存放位置）
DUCKDB_DATA_DIR=data/duckdb

# ── CORS ─────────────────────────────────────────────────────────────────────
# 預設已包含 localhost:3000/3001/3002/5173，需覆寫時取消註解
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── 進階調整（有預設值，通常不需修改）────────────────────────────────────────

# Chat 參考資料字元上限（BI／一般附檔），超過回傳 413（預設 100000）
# CHAT_DATA_MAX_CHARS=100000

# Chat Agent 附件注入上限，配合本機約 32K context（預設 24000）
# CHAT_AGENT_REFERENCE_MAX_CHARS=24000

# 計算失敗時是否在回應末段附加後端錯誤與 SQL，開發除錯用（預設 false）
# EXPOSE_COMPUTE_ERROR_DETAIL=false

# 語音轉文字（faster-whisper-server，OpenAI-compatible）；留空停用語音功能
WHISPER_BASE_URL=http://your-whisper-server:8002
