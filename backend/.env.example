# NeuroSme2.0 專用 PostgreSQL (docker compose up -d)
# port 5434 避免與 local auth 的 PostgreSQL 衝突
DATABASE_URL=postgresql://neurosme:neurosme_secret@localhost:5434/neurosme2

# LLM API（chat 測試頁使用）
OPENAI_API_KEY=sk-your-openai-api-key
# GEMINI_API_KEY=your-gemini-key
# 台智雲（取得 key 與端點後填入）
# TWCC_API_KEY=your-twcc-key
# TWCC_API_BASE=https://your-twcc-endpoint.twcc.ai/v1
# CORS 預設已包含 3000-3002，可覆寫
# CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002"]
